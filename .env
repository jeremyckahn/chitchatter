# 畅聊环境配置
# 复制此文件为 .env 并根据需要修改

# =============================================================================
# 信令服务器配置
# =============================================================================

# 信令服务器 WebSocket URL
# 本地开发: ws://localhost:8787
# 生产环境: wss://your-worker.your-subdomain.workers.dev
# VITE_SIGNALING_SERVER_URL=ws://localhost:8787

# =============================================================================
# API 配置
# =============================================================================

# TURN 配置 API 端点
# 设置后在设置页面中启用"增强连接"功能
# VITE_RTC_CONFIG_ENDPOINT=/api/get-config

# API 基础 URL（仅开发环境）
# VITE_API_BASE_URL=http://localhost:8787

# =============================================================================
# RTC 配置（生产环境）
# =============================================================================

# Base64 编码的 RTCConfiguration JSON 字符串
# 用于 /api/get-config 端点提供 STUN/TURN 服务器
#
# 生成方式:
# 1. 使用辅助脚本: npm run generate-rtc-config
# 2. 手动创建: echo '{"iceServers":[...]}' | base64 -w 0
#
# RTC_CONFIG=eyJpY2VTZXJ2ZXJzIjpbeyJ1cmxzIjoic3R1bjpzdHVuLmwuZ29vZ2xlLmNvbToxOTMwMiJ9XX0=

# =============================================================================
# 开发服务
# =============================================================================

# WebTorrent Tracker URL（文件传输的对等发现）
# VITE_TRACKER_URL=ws://localhost:8000

# StreamSaver URL（大文件下载）
# VITE_STREAMSAVER_URL=http://localhost:3015/mitm.html

# =============================================================================
# 应用设置
# =============================================================================

# 路由模式: "browser"（默认）或 "hash"
# VITE_ROUTER_TYPE=hash

# 应用首页 URL
# VITE_HOMEPAGE=https://your-domain.com/

# GitHub 仓库 URL
VITE_GITHUB_REPO="https://github.com/Shannon-x/chitchatter"
